---
import Layout from '../layouts/Layout.astro';
import ShieldLogo from '../components/ShieldLogo.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- Background Canvas -->
  <canvas id="bg-canvas" class="fixed inset-0 -z-10"></canvas>

  <!-- Scrollable page -->
  <div class="relative z-10">

    <!-- Hero Section — full viewport -->
    <section class="h-dvh flex flex-col items-center justify-center px-5 md:px-6">

      <!-- Logo & Name (no .reveal — must be visible for LCP) -->
      <div class="text-center mb-6 md:mb-10">
        <!-- Shield + D logo -->
        <ShieldLogo class="mx-auto mb-3 md:mb-6 w-12 h-14 md:w-20 md:h-[5.5rem]" />

        <h1 class="font-display text-4xl md:text-7xl tracking-wide text-bg-dark mb-2 md:mb-4"
            style="text-shadow: 0 1px 2px rgba(0,0,0,0.06);">
          Dueydo
        </h1>
        <p class="font-accent text-lg md:text-2xl text-text-secondary italic tracking-wide">
          Private secure chat for friends 🍻
        </p>
      </div>

      <!-- Three Pillars — philosophy row -->
      <h2 class="sr-only">Our Principles</h2>
      <div class="flex flex-row md:grid md:grid-cols-3 gap-3 md:gap-6 max-w-3xl w-full mb-6 md:mb-10 reveal" style="transition-delay: 0.15s;">
        <div class="flex-1 text-center px-3 py-4 md:p-6 rounded-lg bg-bg-card/60 backdrop-blur-sm border border-border-subtle">
          <!-- Shield icon -->
          <div class="mx-auto mb-2 md:mb-3 w-6 h-6 md:w-8 md:h-8">
            <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
              <path d="M12 2l8 4v5c0 5.5-3.8 10.7-8 12-4.2-1.3-8-6.5-8-12V6l8-4z"/>
              <path d="M12 8v4m0 2h.01" stroke-width="2"/>
            </svg>
          </div>
          <h3 class="font-heading text-xs md:text-sm uppercase tracking-widest text-gold-dim mb-1 md:mb-2">Fortified</h3>
          <p class="hidden md:block text-sm text-text-tertiary leading-relaxed">
            Signal Protocol encryption. Your words are yours alone.
          </p>
          <p class="md:hidden text-xs text-text-tertiary leading-snug">
            Signal Protocol E2EE
          </p>
        </div>
        <div class="flex-1 text-center px-3 py-4 md:p-6 rounded-lg bg-bg-card/60 backdrop-blur-sm border border-border-subtle">
          <!-- Hourglass icon -->
          <div class="mx-auto mb-2 md:mb-3 w-6 h-6 md:w-8 md:h-8">
            <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
              <path d="M6 2h12M6 22h12M7 2v4a5 5 0 005 5 5 5 0 005-5V2M7 22v-4a5 5 0 015-5 5 5 0 015 5v4"/>
              <circle cx="12" cy="12" r="1" fill="#C9A84C" stroke="none"/>
            </svg>
          </div>
          <h3 class="font-heading text-xs md:text-sm uppercase tracking-widest text-gold-dim mb-1 md:mb-2">Ephemeral</h3>
          <p class="hidden md:block text-sm text-text-tertiary leading-relaxed">
            Messages vanish after two weeks. No archives, no traces.
          </p>
          <p class="md:hidden text-xs text-text-tertiary leading-snug">
            Auto-deletes in 14 days
          </p>
        </div>
        <div class="flex-1 text-center px-3 py-4 md:p-6 rounded-lg bg-bg-card/60 backdrop-blur-sm border border-border-subtle">
          <!-- Crossed swords icon -->
          <div class="mx-auto mb-2 md:mb-3 w-6 h-6 md:w-8 md:h-8">
            <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
              <path d="M4 20L18 4M4 20l2-2m-2 2l-2-2m16-12l2 2m-2-2l-2-2"/>
              <path d="M20 20L6 4M20 20l-2-2m2 2l2-2M6 4L4 6M6 4l2-2"/>
            </svg>
          </div>
          <h3 class="font-heading text-xs md:text-sm uppercase tracking-widest text-gold-dim mb-1 md:mb-2">Sovereign</h3>
          <p class="hidden md:block text-sm text-text-tertiary leading-relaxed">
            EU infrastructure. Zero-knowledge server. Your data stays yours.
          </p>
          <p class="md:hidden text-xs text-text-tertiary leading-snug">
            EU zero-knowledge infra
          </p>
        </div>
      </div>

      <!-- Scroll hint on desktop -->
      <div class="hidden md:block absolute bottom-8 animate-bounce reveal" style="transition-delay: 0.6s;">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 opacity-40">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </div>
    </section>

    <!-- Features Section — dark background -->
    <section class="px-5 md:px-6 py-14 md:py-24 bg-bg-dark">
      <div class="max-w-4xl mx-auto">

        <!-- Section heading -->
        <div class="text-center mb-8 md:mb-14 reveal">
          <h2 class="font-heading text-sm md:text-base uppercase tracking-[0.2em] text-gold mb-3">More Than a Messenger</h2>
          <p class="font-accent text-base md:text-lg text-text-inverse/70 italic">
            Security shouldn't mean settling for less. Rich features, zero compromise.
          </p>
        </div>

        <!-- Feature cards — 2x2 grid, glass on dark -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6 reveal" style="transition-delay: 0.15s;">

          <!-- Threads -->
          <div class="p-5 md:p-7 rounded-xl bg-white/[0.06] shadow-lg shadow-black/20">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 md:w-9 md:h-9 shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                  <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                  <path d="M14 10H8m4 4H8" stroke-width="1.5"/>
                </svg>
              </div>
              <h3 class="font-heading text-sm md:text-base uppercase tracking-widest text-gold">Threads</h3>
            </div>
            <p class="text-sm text-text-inverse/60 leading-relaxed">
              Reply to any message to start a focused side conversation. The main chat stays clean while you dive deep into any topic.
            </p>
          </div>

          <!-- Posts -->
          <div class="p-5 md:p-7 rounded-xl bg-white/[0.06] shadow-lg shadow-black/20">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 md:w-9 md:h-9 shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                  <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                  <path d="M14 2v6h6M8 13h8m-8 4h5"/>
                </svg>
              </div>
              <h3 class="font-heading text-sm md:text-base uppercase tracking-widest text-gold">Posts</h3>
            </div>
            <p class="text-sm text-text-inverse/60 leading-relaxed">
              Share ideas worth keeping. Long-form posts with rich formatting live alongside your chat — they don't vanish like messages do.
            </p>
          </div>

          <!-- Duress PIN -->
          <div class="p-5 md:p-7 rounded-xl bg-white/[0.06] shadow-lg shadow-black/20">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 md:w-9 md:h-9 shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="M9 12l2 2 4-4" stroke-width="2"/>
                </svg>
              </div>
              <h3 class="font-heading text-sm md:text-base uppercase tracking-widest text-gold">Duress PIN</h3>
            </div>
            <p class="text-sm text-text-inverse/60 leading-relaxed">
              A second PIN that silently shows fake conversations if you're ever forced to unlock. Your real messages stay hidden. Recover everything when you're safe.
            </p>
          </div>

          <!-- Encrypted Media -->
          <div class="p-5 md:p-7 rounded-xl bg-white/[0.06] shadow-lg shadow-black/20">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 md:w-9 md:h-9 shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <path d="M21 15l-5-5L5 21"/>
                </svg>
              </div>
              <h3 class="font-heading text-sm md:text-base uppercase tracking-widest text-gold">Encrypted Media</h3>
            </div>
            <p class="text-sm text-text-inverse/60 leading-relaxed">
              Share photos, videos, and documents with the same Signal-level encryption as your messages. Everything auto-deletes after two weeks.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Screenshot Gallery — dark background continues -->
    <section class="px-5 md:px-6 py-14 md:py-24 bg-bg-dark">
      <div class="max-w-4xl mx-auto">

        <!-- Section heading -->
        <div class="text-center mb-10 md:mb-16 reveal">
          <h2 class="font-heading text-sm md:text-base uppercase tracking-[0.2em] text-gold mb-3">See It In Action</h2>
          <p class="font-accent text-base md:text-lg text-text-inverse/70 italic">
            Light mode or dark mode. Your conversations, your way.
          </p>
        </div>

        <!-- Chat -->
        <div class="mb-12 md:mb-16 reveal" style="transition-delay: 0.1s;">
          <div class="screenshot-pair">
            <div class="phone-frame">
              <img src="/screenshots/chat-light-mobile.png" alt="Dueydo chat in light mode" loading="lazy" width="1170" height="2532" />
            </div>
            <div class="phone-frame">
              <img src="/screenshots/chat-dark-mobile.png" alt="Dueydo chat in dark mode" loading="lazy" width="1170" height="2532" />
            </div>
          </div>
          <p class="text-center mt-4 md:mt-5 text-sm text-text-inverse/50 font-accent italic">
            End-to-end encrypted conversations
          </p>
        </div>

        <!-- Threads -->
        <div class="mb-12 md:mb-16 reveal" style="transition-delay: 0.1s;">
          <div class="screenshot-pair">
            <div class="phone-frame">
              <img src="/screenshots/thread-light-mobile.png" alt="Dueydo thread in light mode" loading="lazy" width="1170" height="2532" />
            </div>
            <div class="phone-frame">
              <img src="/screenshots/thread-dark-mobile.png" alt="Dueydo thread in dark mode" loading="lazy" width="1170" height="2532" />
            </div>
          </div>
          <p class="text-center mt-4 md:mt-5 text-sm text-text-inverse/50 font-accent italic">
            Focused side conversations in threads
          </p>
        </div>

        <!-- Posts List -->
        <div class="mb-12 md:mb-16 reveal" style="transition-delay: 0.1s;">
          <div class="screenshot-pair">
            <div class="phone-frame">
              <img src="/screenshots/posts-list-light-mobile.png" alt="Dueydo posts in light mode" loading="lazy" width="1170" height="2532" />
            </div>
            <div class="phone-frame">
              <img src="/screenshots/posts-list-dark-mobile.png" alt="Dueydo posts in dark mode" loading="lazy" width="1170" height="2532" />
            </div>
          </div>
          <p class="text-center mt-4 md:mt-5 text-sm text-text-inverse/50 font-accent italic">
            Long-form posts that persist
          </p>
        </div>

        <!-- Post Detail -->
        <div class="reveal" style="transition-delay: 0.1s;">
          <div class="screenshot-pair">
            <div class="phone-frame">
              <img src="/screenshots/post-detail-light-mobile.png" alt="Dueydo post detail in light mode" loading="lazy" width="1170" height="2532" />
            </div>
            <div class="phone-frame">
              <img src="/screenshots/post-detail-dark-mobile.png" alt="Dueydo post detail in dark mode" loading="lazy" width="1170" height="2532" />
            </div>
          </div>
          <p class="text-center mt-4 md:mt-5 text-sm text-text-inverse/50 font-accent italic">
            Rich post detail with comments
          </p>
        </div>

      </div>
    </section>

    <!-- Quote + Coming Soon + Footer — dark background continues -->
    <section class="px-5 md:px-6 pb-8 md:pb-12 bg-bg-dark">
      <div class="max-w-4xl mx-auto text-center">

        <!-- Tagline -->
        <div class="mb-6 md:mb-10 reveal">
          <p class="font-accent text-base md:text-lg text-text-inverse/60 leading-relaxed italic">
            "Even the monks who brewed the finest ales<br class="hidden md:inline"/>
            needed walls to keep their conversations safe."
          </p>
        </div>

        <!-- Coming Soon -->
        <div class="mb-8 md:mb-12 reveal" style="transition-delay: 0.15s;">
          <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-gold bg-bg-dark">
            <div class="w-2 h-2 rounded-full bg-gold animate-pulse"></div>
            <span class="font-heading text-xs uppercase tracking-[0.2em] text-gold">Coming Soon</span>
          </div>
        </div>

        <!-- Footer -->
        <Footer />

      </div>
    </section>

  </div>

  <!-- Background Animation -->
  <script>
    const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    let width: number, height: number;
    let mouseX = -1, mouseY = -1;
    let animFrame: number;

    // Lighter parchment palette — pushed toward cream/white
    const COLORS = [
      { r: 252, g: 250, b: 247 },  // near-white cream
      { r: 248, g: 245, b: 238 },  // light parchment
      { r: 244, g: 240, b: 232 },  // warm paper
      { r: 240, g: 236, b: 226 },  // soft sand
      { r: 236, g: 231, b: 220 },  // light stone
    ];

    // Gold accent for mouse proximity
    const GOLD = { r: 201, g: 168, b: 76 };

    interface Stone {
      x: number;       // current x (includes drift)
      y: number;       // current y (includes drift)
      baseX: number;   // origin x for grid position
      baseY: number;   // origin y for grid position
      size: number;
      colorIdx: number;
      phase: number;       // breathing phase offset
      speed: number;       // breathing speed
      driftAngle: number;  // direction of drift
      driftSpeed: number;  // how fast it drifts (px/s)
      driftRadius: number; // max wander distance from origin
      driftPhase: number;  // phase offset for drift oscillation
    }

    let stones: Stone[] = [];

    function resize() {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
      generateStones();
    }

    function generateStones() {
      stones = [];
      const spacing = 65;
      const cols = Math.ceil(width / spacing) + 3;
      const rows = Math.ceil(height / spacing) + 3;

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const baseX = c * spacing + (r % 2 ? spacing / 2 : 0) + (Math.random() - 0.5) * 20;
          const baseY = r * spacing + (Math.random() - 0.5) * 20;
          stones.push({
            x: baseX,
            y: baseY,
            baseX,
            baseY,
            size: spacing * 0.35 + Math.random() * spacing * 0.3,
            colorIdx: Math.floor(Math.random() * COLORS.length),
            phase: Math.random() * Math.PI * 2,
            speed: 0.2 + Math.random() * 0.3,
            driftAngle: Math.random() * Math.PI * 2,
            driftSpeed: 0.15 + Math.random() * 0.25,  // slow wandering
            driftRadius: 8 + Math.random() * 16,       // wander 8-24px from origin
            driftPhase: Math.random() * Math.PI * 2,
          });
        }
      }
    }

    function draw(time: number) {
      const t = time * 0.001;
      ctx.clearRect(0, 0, width, height);

      // Fill base — same cream as bg-primary
      ctx.fillStyle = '#FAF8F3';
      ctx.fillRect(0, 0, width, height);

      for (const stone of stones) {
        // Slow drift: each circle oscillates around its origin
        const driftX = Math.sin(t * stone.driftSpeed + stone.driftPhase) * stone.driftRadius;
        const driftY = Math.cos(t * stone.driftSpeed * 0.7 + stone.driftAngle) * stone.driftRadius * 0.8;
        stone.x = stone.baseX + driftX;
        stone.y = stone.baseY + driftY;

        // Gentle breathing pulse
        const pulse = Math.sin(t * stone.speed + stone.phase) * 0.5 + 0.5;
        const c = COLORS[stone.colorIdx];

        // Mouse proximity — subtle gold warmth
        let goldInfluence = 0;
        if (mouseX >= 0) {
          const dx = stone.x - mouseX;
          const dy = stone.y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          goldInfluence = Math.max(0, 1 - dist / 180) * 0.25;
        }

        // Keep it light: low alpha, gentle color shift
        const r = Math.round(c.r + (GOLD.r - c.r) * goldInfluence);
        const g = Math.round(c.g + (GOLD.g - c.g) * goldInfluence);
        const b = Math.round(c.b + (GOLD.b - c.b) * goldInfluence);
        const alpha = 0.15 + pulse * 0.12 + goldInfluence * 0.2;

        ctx.beginPath();
        ctx.arc(stone.x, stone.y, stone.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        ctx.fill();
      }

      animFrame = requestAnimationFrame(draw);
    }

    // Events
    window.addEventListener('resize', resize);
    window.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });
    window.addEventListener('mouseleave', () => { mouseX = -1; mouseY = -1; });

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Init
    resize();
    animFrame = requestAnimationFrame(draw);
  </script>
</Layout>
